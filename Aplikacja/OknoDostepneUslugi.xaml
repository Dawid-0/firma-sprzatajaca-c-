<Window x:Class="Aplikacja.OknoDostepneUslugi"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dostępne usługi"
        Height="750"
        Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        ResizeMode="NoResize"
        Closing="Window_Closing">

    <StackPanel Margin="20">

        <Button Content="Wróć"
                Click="Powrot_Click"
                Width="120"
                HorizontalAlignment="Left"
                Margin="0,0,0,10"
                Background="#FF376AD9"
                Foreground="White"/>

        <Border Background="#4F46E5" CornerRadius="15" Margin="0,0,0,20">
            <TextBlock Text="Dostępne usługi"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="20"/>
        </Border>

        <DataGrid x:Name="dgUslugi"
                  AutoGenerateColumns="False"
                  Height="300"
                  ColumnWidth="*"
                  Margin="0,0,0,20">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="Auto"/>
                <DataGridTextColumn Header="Nazwa" Binding="{Binding NazwaUslugi}"/>
                <DataGridTextColumn Header="Cena" Binding="{Binding CenaPodstawowa}"/>
                <DataGridTextColumn Header="Opis" Binding="{Binding Opis}"/>
            </DataGrid.Columns>

        </DataGrid>

        <StackPanel Background="White" >

            <TextBlock Text="Dodaj usługę"
                       FontWeight="Bold"
                       FontSize="16"
                       Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal">

                <StackPanel Margin="10">
                    <Label Content="Nazwa"/>
                    <TextBox x:Name="txtNazwa" Width="200"/>
                </StackPanel>

                <StackPanel Margin="10">
                    <Label Content="Cena"/>
                    <TextBox x:Name="txtCena" Width="200"/>
                </StackPanel>

                <StackPanel Margin="10">
                    <Label Content="Opis"/>
                    <TextBox x:Name="txtOpis" Width="200"/>
                </StackPanel>

                <StackPanel Margin="10">
                    <Label Content="Sprzęt"/>
                    <ComboBox x:Name="cbSprzet"
                              Width="200"
                              DisplayMemberPath="Nazwa"
                              SelectedValuePath="Id"/>
                </StackPanel>

            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="10">

                <Button Content="Dodaj"
                        Click="Dodaj_Click"
                        Width="120"
                        Margin="5"
                        Background="#FF376AD9"
                        Foreground="White"/>

                <Button Content="Usuń"
                        Click="Usun_Click"
                        Width="120"
                        Margin="5"
                        Background="#CE2121"
                        Foreground="White"/>

            </StackPanel>

        </StackPanel>

    </StackPanel>
</Window>