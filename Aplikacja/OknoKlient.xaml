<Window x:Class="Aplikacja.OknoKlient"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panel Klienta"
        Height="650"
        Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F7FA">
    <Grid>
        <StackPanel>
            <Grid Margin="20,20,20,10">

                <Button Content="Powrót"
                Width="100"
                Height="35"
                HorizontalAlignment="Left"
                Click="btnPowrot_Click"/>

            </Grid>
            <Border Background="#4F46E5"
                    CornerRadius="15"
                    Padding="20,10"
                    Margin="0,20,0,30"
                    HorizontalAlignment="Center">
                <TextBlock Text="Panel Klienta"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"/>
            </Border>
            <WrapPanel Margin="40,10">
                <Button Width="180"
                        Height="100"
                        Background="#eb3461"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Content="Sprawdź usługi"
                        Click="SprawdzUslugi_Click"/>

                <TextBlock Margin="20,35,0,0"
                           FontSize="15"
                           Text="Sprawdź liste oferowanych przez nas usług."/>

            </WrapPanel>

            <WrapPanel Margin="40,10">
                <Button Width="180"
                        Height="100"
                        Background="#22C55E"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Content="Utworz zlecenie"
                        Click="UtworzZlecenie_Click"/>

                <TextBlock Margin="20,35,0,0"
                           FontSize="15"
                           Text="Dodaj nowe zlecenie do realizacji."/>

            </WrapPanel>

            <WrapPanel Margin="40,10">

                <Button Width="180"
                        Height="100"
                        Background="#3B82F6"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Content="Sprawdz zlecenia"
                        Click="Sprawdz_zamowienia_Click"/>

                <TextBlock Margin="20,35,0,0"
                           FontSize="15"
                           Text="Wyświetl swoje aktualne zlecenia."/>
            </WrapPanel>
        </StackPanel>
    </Grid>
</Window>