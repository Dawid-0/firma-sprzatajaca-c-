<Window x:Class="Aplikacja.OknoAdmin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panel Administratora"
        Height="550"
        Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Closing="Window_Closing">

    <Grid>

        <StackPanel VerticalAlignment="Top">
        

            <Border Background="#4F46E5"
                    CornerRadius="15"
                    Padding="10,10"
                    Margin="0,20,0,30"
                    HorizontalAlignment="Center">

            <TextBlock Text="Panel administratora"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"/>
            </Border>

            <WrapPanel HorizontalAlignment="Center" Margin="0,60,0,0">

                <Button Width="150"
                        Height="120"
                        Margin="10"
                        Background="#4F46E5"
                        Foreground="White"
                        BorderBrush="#4F46E5"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Content="Dostepny sprzet" Click="Sprzet_Click"/>
                
                <Button Width="150"
                Height="120"
                Margin="10"
                Background="#4F46E5"
                Foreground="White"
                BorderBrush="#4F46E5"
                FontSize="16"
                FontWeight="SemiBold"
                Cursor="Hand"
                Content="Dostepne uslugi"/>

                <Button Width="150"
                    Height="120"
                    Margin="10"
                    Background="#4F46E5"
                    Foreground="White"
                    BorderBrush="#4F46E5"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Cursor="Hand"
                    Content="Zlecenia"/>
                <Button Width="150"
                    Height="120"
                    Margin="10"
                    Background="#4F46E5"
                    Foreground="White"
                    BorderBrush="#4F46E5"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Cursor="Hand"
                    Content="Pracownicy" Click="Pracownicy_Click"/>
                <Button Width="150"
                    Height="120"
                    Margin="10"
                    Background="#4F46E5"
                    Foreground="White"
                    BorderBrush="#4F46E5"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Cursor="Hand"
                    Content="Klienci"/>
                <Button Width="150"
                        Height="120"
                        Margin="10"
                        Background="Red"
                        Foreground="White"
                        BorderBrush="#4F46E5"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="Wyloguj_Click"
                        Content="Wyloguj"/>

            </WrapPanel>

        </StackPanel>

    </Grid>

</Window>