<Window x:Class="Aplikacja.OknoWyboruLogowania"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Aplikacja"
        mc:Ignorable="d"
        Title="Wybór użytkownika"
        Height="350"
        Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F7FA"
        Closing="Window_Closing">

    <Grid>

        <StackPanel VerticalAlignment="Center">

            <Border Background="#4F46E5"
                    CornerRadius="15"
                    Padding="20,10"
                    Margin="0,20,0,30"
                    HorizontalAlignment="Center">

                <TextBlock Text="Kim jesteś?"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"/>
            </Border>

            <WrapPanel HorizontalAlignment="Center">

                <Button Width="150"
                        Height="120"
                        Margin="10"
                        Click="Admin_Click"
                        Background="#4F46E5"
                        Foreground="White"
                        BorderBrush="#4F46E5"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Content="Administrator"/>

                <Button Width="150"
                        Height="120"
                        Margin="10"
                        Click="Klient_Click"
                        Background="#4F46E5"
                        Foreground="White"
                        BorderBrush="#4F46E5"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Content="Klient"/>

            </WrapPanel>

        </StackPanel>

    </Grid>

</Window>