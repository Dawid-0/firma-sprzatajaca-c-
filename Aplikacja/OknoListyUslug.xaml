<Window x:Class="Aplikacja.OknoListyUslug"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Usługi"
        Height="750"
        Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Grid Margin="20">
        <StackPanel>

            <Button x:Name="btnPowrot"
                    Content="Powrót"
                    Width="120"
                    Height="35"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,15"
                    Click="btnPowrot_Click"/>

            <Border Background="#eb3461"
                    CornerRadius="15"
                    Padding="15"
                    Margin="0,0,0,30">

                <TextBlock Text="Usługi"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"/>

            </Border>

            <WrapPanel Margin="0,0,0,40">

                <StackPanel Width="250">

                    <TextBlock Text="Wybierz usługę"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <ComboBox x:Name="cmbUslugi"
                              Width="220"
                              Height="35"
                              FontSize="15"
                              SelectionChanged="cmbUslugi_SelectionChanged"/>

                </StackPanel>

            </WrapPanel>

            <TextBlock Text="Informacje o usłudze"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <TextBlock x:Name="txtNazwa"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10"/>

            <TextBlock x:Name="txtCena"
                       FontSize="16"
                       Margin="0,0,0,10"/>

            <TextBlock x:Name="txtOpis"
                       FontSize="16"
                       TextWrapping="Wrap"
                       Margin="0,0,0,30"/>

            <TextBlock Text="Sprzęt wykorzystywany do usługi"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,15"/>

            <ListBox x:Name="lstSprzet"
                     Height="150"/>

        </StackPanel>
    </Grid>

</Window>