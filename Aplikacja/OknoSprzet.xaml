<Window x:Class="Aplikacja.OknoSprzet" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zarządzanie sprzetem"
        Height="748" 
        Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        ResizeMode="NoResize"
        Closing="Window_Closing">

    <StackPanel Margin="20">

        <Button Content="Wróć" Click="Powrot_Click" HorizontalAlignment="Left" Width="120" Margin="0,0,0,10" Background="#FF376AD9" BorderBrush="#FF342929" Foreground="#FFF1F1F1" Height="25" FontSize="14"/>

        <Border Background="#4F46E5" CornerRadius="15" Margin="0,0,0,20">
            <TextBlock Text="Zarządzanie sprzętem" FontSize="28" FontWeight="Bold" Foreground="White" 
            HorizontalAlignment="Center" Margin="20"/>
        </Border>

        <DataGrid x:Name="dgSprzet" AutoGenerateColumns="True" Height="350" Margin="0,0,0,20"/>

        <StackPanel Background="White" Orientation="Vertical">

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                <StackPanel Margin="10">
                    <Label Content="Nazwa"/>
                    <TextBox x:Name="txtNazwa" Width="200" Height="30"/>
                </StackPanel>

                <StackPanel Margin="10">
                    <Label Content="Typ"/>
                    <TextBox x:Name="txtTyp" Width="200" Height="30"/>
                </StackPanel>

                <StackPanel Margin="10">
                    <Label Content="Krótki opis"/>
                    <TextBox x:Name="txtOpis" Width="200" Height="30"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <Button Content="Dodaj" Click="Dodaj_Click" Width="100" Margin="5" Background="#FF376AD9" BorderBrush="#FF342929" Foreground="#FFF1F1F1" Height="36" FontSize="14"/>
                <Button Content="Usuń" Click="Usun_Click" Width="100" Margin="5" Foreground="#FFF4F4F4" BorderBrush="#FF373434" Background="#FFCE2121" Height="38" FontSize="14"/>
            </StackPanel>
        </StackPanel>

    </StackPanel>
</Window>