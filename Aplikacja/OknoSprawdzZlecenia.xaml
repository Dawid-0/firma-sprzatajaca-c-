<Window x:Class="Aplikacja.OknoSprawdzZlecenia"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Moje zlecenia"
        Height="650"
        Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Grid Margin="20">
        <StackPanel>

            <Button x:Name="btnPowrot"
                    Content="Powrót"
                    Width="120"
                    Height="35"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,15"
                    Click="btnPowrot_Click"/>

            <Border Background="#3B82F6"
                    CornerRadius="15"
                    Padding="15"
                    Margin="0,0,0,30">

                <TextBlock Text="Moje zlecenia"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"/>

            </Border>

            <TextBlock Text="Aktualne zlecenia"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,15"/>

            <DataGrid x:Name="dgZlecenia"
                      Height="450"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"
                      CanUserAddRows="False"/>

        </StackPanel>
    </Grid>

</Window>