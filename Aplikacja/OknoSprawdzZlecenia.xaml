<Window x:Class="Aplikacja.OknoSprawdzZlecenia"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Moje zlecenia"
        Height="650"
        Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Grid Margin="20">
        <StackPanel>

            <Button x:Name="btnPowrot"
                    Content="Powrót"
                    Width="120"
                    Height="35"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,15"
                    Click="btnPowrot_Click"/>

            <Border Background="#3B82F6"
                    CornerRadius="15"
                    Padding="15"
                    Margin="0,0,0,30">

                <TextBlock Text="Moje zlecenia"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"/>

            </Border>

            <TextBlock Text="Aktualne zlecenia"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,15"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                
                <TextBlock Text="Klient:"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"/>

                <ComboBox x:Name="cbKlienci"
                  Width="250"
                  SelectionChanged="cbKlienci_SelectionChanged"/>
                
            </StackPanel>
            
            <DataGrid x:Name="dgZlecenia"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              Height="450"
              SelectionMode="Single">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Klient"
                            Binding="{Binding WybranyKlient.PelneDane}"
                            Width="120"/>

                    <DataGridTextColumn Header="Usługa"
                            Binding="{Binding WybranaUsluga.NazwaUslugi}" 
                            Width="120"/>

                    <DataGridTextColumn Header="Pracownik"
                            Binding="{Binding Pracownik.PelneNazwisko}" 
                            Width="200"/>

                    <DataGridTextColumn Header="Sprzęt"
                            Binding="{Binding Sprzet.Nazwa}" 
                            Width="200"/>

                    <DataGridTextColumn Header="Od"
                            Binding="{Binding DataOd, StringFormat=dd.MM.yyyy}"
                            Width="120"/>

                    <DataGridTextColumn Header="Do"
                            Binding="{Binding DataDo, StringFormat=dd.MM.yyyy}"
                            Width="120"/>

                </DataGrid.Columns>

            </DataGrid>

        </StackPanel>
    </Grid>

</Window>