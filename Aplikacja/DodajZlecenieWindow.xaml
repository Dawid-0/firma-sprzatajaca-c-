<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="Aplikacja.DodajZlecenieWindow"
        Title="Nowe Zlecenie - Panel Administratora" Height="600" Width="700"
        WindowStartupLocation="CenterScreen" Background="#F5F5F7">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="DODAWANIE NOWEGO ZLECENIA" FontSize="18" Foreground="#333" Margin="0,0,0,20"/>

        <UniformGrid Rows="1" Columns="2" Grid.Row="1" Margin="0,0,0,15">
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Wybierz Klienta:" Margin="0,0,0,5"/>
                <ComboBox Height="30" ItemsSource="{Binding Klienci}" DisplayMemberPath="Nazwa" SelectedItem="{Binding WybranyKlient}"/>
            </StackPanel>

            <StackPanel Margin="10,0,0,0">
                <TextBlock Text="Rodzaj Usługi:" Margin="0,0,0,5"/>
                <ComboBox Height="30" ItemsSource="{Binding Uslugi}" DisplayMemberPath="Nazwa" SelectedItem="{Binding WybranaUsluga}"/>
            </StackPanel>
        </UniformGrid>

        <UniformGrid Rows="1" Columns="2" Grid.Row="2" Margin="0,0,0,15">
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Data i godz. rozpoczęcia:" Margin="0,0,0,5"/>
                <DatePicker SelectedDate="{Binding DataOd}" Height="30"/>
            </StackPanel>

            <StackPanel Margin="10,0,0,0">
                <TextBlock Text="Data i godz. zakończenia:" Margin="0,0,0,5"/>
                <DatePicker SelectedDate="{Binding DataDo}" Height="30"/>
            </StackPanel>
        </UniformGrid>

        <UniformGrid Rows="1" Columns="2" Grid.Row="3" Margin="0,0,0,20">

            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Przypisz Pracowników:" Margin="0,0,0,5"/>
                <ListBox ItemsSource="{Binding Pracownicy}" Height="200" BorderBrush="#DDD">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <CheckBox IsChecked="{Binding CzyWybrany, Mode=TwoWay}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding PelneNazwisko}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

            <StackPanel Margin="10,0,0,0">
                <TextBlock Text="Zarezerwuj Sprzęt:" Margin="0,0,0,5"/>
                <ListBox ItemsSource="{Binding Sprzety}" Height="200" BorderBrush="#DDD">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <CheckBox IsChecked="{Binding CzyWybrany, Mode=TwoWay}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Nazwa}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

        </UniformGrid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Anuluj" Width="100" Height="35" Margin="0,0,10,0" Background="#E0E0E0" BorderThickness="0" Click="Anuluj_Click"/>
            <Button Content="Zapisz Zlecenie" Width="140" Height="35" Background="#007ACC" Foreground="White" Click="Zapisz_Click"/>
        </StackPanel>
    </Grid>
</Window>